{
    "name": "vortex-rdf",
    "version": "0.1.0",
    "description": "High-performance, columnar RDF serialization format",
    "main": "pkg/vortex_rdf.js",
    "types": "pkg/vortex_rdf.d.ts",
    "files": [
        "pkg/vortex_rdf_bg.wasm",
        "pkg/vortex_rdf.js",
        "pkg/vortex_rdf.d.ts"
    ],
    "scripts": {
        "build:node": "wasm-pack build --target nodejs --out-dir pkg",
        "build:web": "wasm-pack build --target web --out-dir pkg",
        "test": "vitest run"
    },
    "keywords": [
        "rdf",
        "vortex",
        "columnar",
        "semantic-web",
        "wasm",
        "zero-copy"
    ],
    "author": "Julián Rojas",
    "license": "MIT",
    "devDependencies": {
        "@rdfjs/types": "^2.0.1",
        "@types/node": "^26.1.1",
        "rdf-data-factory": "^2.0.2",
        "typescript": "^7.0.2",
        "vitest": "^4.1.10",
        "wasm-pack": "^0.15.0"
    }
}
