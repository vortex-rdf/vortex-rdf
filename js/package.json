{
    "name": "vortex-rdf",
    "version": "0.1.0",
    "description": "High-performance, columnar RDF serialization format",
    "type": "module",
    "main": "./entry/browser.js",
    "types": "./pkg/web/vortex_rdf.d.ts",
    "exports": {
        ".": {
            "types": "./pkg/web/vortex_rdf.d.ts",
            "node": "./entry/node.js",
            "browser": "./entry/browser.js",
            "default": "./entry/browser.js"
        }
    },
    "files": [
        "entry/node.js",
        "entry/browser.js",
        "pkg/web/vortex_rdf.js",
        "pkg/web/vortex_rdf.d.ts",
        "pkg/web/vortex_rdf_bg.wasm",
        "pkg/web/vortex_rdf_bg.wasm.d.ts"
    ],
    "scripts": {
        "build:wasm": "wasm-pack build --target web --out-dir pkg/web",
        "build": "npm run build:wasm",
        "test": "vitest run"
    },
    "keywords": [
        "rdf",
        "vortex",
        "columnar",
        "semantic-web",
        "wasm",
        "zero-copy"
    ],
    "author": "Julián Rojas",
    "license": "MIT",
    "devDependencies": {
        "@rdfjs/types": "^2.0.1",
        "@types/node": "^26.1.1",
        "rdf-data-factory": "^2.0.2",
        "typescript": "^7.0.2",
        "vitest": "^4.1.10",
        "wasm-pack": "^0.15.0"
    }
}
